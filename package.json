{
  "name": "aiecsjs",
  "version": "0.4.1",
  "description": "TypeScript-first archetype ECS with TypedArray SoA, SAB-ready snapshot transport, and AI-readable docs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./loop": {
      "types": "./dist/loop.d.ts",
      "import": "./dist/loop.js",
      "require": "./dist/loop.cjs"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js",
      "require": "./dist/commands.cjs"
    },
    "./observers": {
      "types": "./dist/observers.d.ts",
      "import": "./dist/observers.js",
      "require": "./dist/observers.cjs"
    },
    "./serialize": {
      "types": "./dist/serialize.d.ts",
      "import": "./dist/serialize.js",
      "require": "./dist/serialize.cjs"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "require": "./dist/worker.cjs"
    },
    "./relations": {
      "types": "./dist/relations.d.ts",
      "import": "./dist/relations.js",
      "require": "./dist/relations.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "README_ZHTW.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt",
    "api.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "yshengliao",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yshengliao/aiecsjs.git"
  },
  "keywords": [
    "ecs",
    "entity-component-system",
    "typescript",
    "archetype",
    "soa",
    "sharedarraybuffer",
    "game",
    "simulation"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "verify:exports": "node scripts/verify-exports.mjs",
    "verify:dist": "node scripts/check-dist-subpaths.mjs",
    "build:llms": "node scripts/build-llms-full.mjs",
    "verify:llms": "node scripts/build-llms-full.mjs --check",
    "check:size": "node scripts/check-size.mjs",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm coverage && pnpm build && pnpm verify:dist && pnpm verify:exports && pnpm verify:llms && pnpm check:size"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^4.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@9.12.3",
  "publishConfig": {
    "access": "public"
  }
}
